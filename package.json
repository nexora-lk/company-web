{
    "name": "my-app",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "analyze": "next build --experimental-analyze",
        "start": "next start",
        "lint": "eslint",
        "test": "jest --watch",
        "test:unit": "jest --testPathPattern=__tests__ --coverage",
        "test:component": "jest components --coverage",
        "test:integration": "jest features --coverage",
        "test:all": "jest --coverage",
        "test:coverage": "jest --coverage && open coverage/lcov-report/index.html",
        "test:ci": "jest --ci --coverage --maxWorkers=2",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:debug": "playwright test --debug",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:chrome": "playwright test --project=chromium",
        "test:e2e:firefox": "playwright test --project=firefox",
        "test:e2e:webkit": "playwright test --project=webkit",
        "test:full": "npm run test:all && npm run test:e2e"
    },
    "dependencies": {
        "@emailjs/browser": "^4.4.1",
        "@next/third-parties": "^16.2.6",
        "@vercel/analytics": "^2.0.1",
        "@vercel/speed-insights": "^2.0.0",
        "critters": "^0.0.23",
        "gsap": "^3.15.0",
        "lenis": "^1.3.23",
        "next": "16.2.6",
        "next-cloudinary": "^6.17.5",
        "react": "19.2.4",
        "react-dom": "19.2.4"
    },
    "browserslist": [
    "chrome >= 96",
    "firefox >= 96",
    "safari >= 15",
    "edge >= 96"
  ],
    "devDependencies": {
        "@next/bundle-analyzer": "^16.2.6",
        "@playwright/test": "^1.60.0",
        "@tailwindcss/postcss": "^4",
        "@testing-library/dom": "^10.0.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^30.0.0",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "16.2.6",
        "jest": "^30.4.2",
        "jest-axe": "^10.0.0",
        "jest-environment-jsdom": "^30.4.1",
        "msw": "^2.14.6",
        "tailwindcss": "^4",
        "ts-jest": "^29.4.11",
        "typescript": "^5"
    }
}
